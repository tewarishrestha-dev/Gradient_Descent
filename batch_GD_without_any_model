
# here the functions are (x-5)**2 , (x-6)**2 , (x-7)**2
x = 20

alpha = 0.1
epochs = 20

for epoch in range(epochs):

    grad1 = 2 * (x - 5)
    grad2 = 2 * (x - 6)
    grad3 = 2 * (x - 7)

    gradient = grad1 + grad2 + grad3

    x = x - alpha * gradient

    print(f"Epoch {epoch+1}: x = {x}")

print("Final x =", x)
